NODE_ENV=test
APP_URL=http://localhost:3000
SESSION_SECRET=test-session-secret
ENCRYPTION_MASTER_KEY=base64:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa=
ENCRYPTION_KEY_VERSION=1

# Tests wipe this database between cases (resetDb) — it must NEVER be the dev
# database `heypay`, or every vitest run destroys dev data and leaves fixture
# rows the workers then choke on (fake Stellar keys, fake PDAX refs).
DATABASE_URL=postgresql://heypay:heypay@localhost:5432/heypay_test?schema=public
SHADOW_DATABASE_URL=postgresql://heypay:heypay@localhost:5432/heypay_shadow?schema=public

REDIS_URL=redis://localhost:6379

ADMIN_USERNAME=admin
ADMIN_PASSWORD=test-admin-pass
SEED_DEMO=false

STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

PAYMENT_RAIL=mock
PDAX_BASE_URL=https://services-stage.pdax.ph/api/exchange/v1
PDAX_ACCESS_KEY=
PDAX_SECRET=
PDAX_TOTP_SECRET=
PDAX_XLM_DEPOSIT_ADDRESS=

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=heypay-uploads
S3_ACCESS_KEY=heypay
S3_SECRET_KEY=heypay-secret
S3_FORCE_PATH_STYLE=true
